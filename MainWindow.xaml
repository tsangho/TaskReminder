<Window x:Class="TaskReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:TaskReminder.Models"
        xmlns:views="clr-namespace:TaskReminder.Views"
        Title="TaskReminder - 定时提醒工具" 
        Height="650" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Window.Resources>
        <!-- Task item template for ListView -->
        <DataTemplate x:Key="TaskItemTemplate">
            <materialDesign:Card Margin="4" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 完成状态图标 -->
                    <CheckBox Grid.Column="0" 
                              IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                              Style="{StaticResource MaterialDesignCheckBox}"
                              VerticalAlignment="Top"
                              Margin="0,0,12,0"/>
                    
                    <!-- 任务信息 -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}" 
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Description}" 
                                   Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                   Opacity="0.7"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <materialDesign:PackIcon Kind="ClockOutline" 
                                                     Width="16" 
                                                     Height="16" 
                                                     Opacity="0.6"/>
                            <TextBlock Text="{Binding DueDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}" 
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}" 
                                       Margin="4,0,0,0"
                                       Opacity="0.6"/>
                            
                            <materialDesign:PackIcon Kind="Repeat" 
                                                     Width="16" 
                                                     Height="16" 
                                                     Margin="16,0,0,0"
                                                     Opacity="0.6"/>
                            <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}" 
                                       Margin="4,0,0,0"
                                       Opacity="0.6">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="RepeatType"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- 删除按钮 -->
                    <Button Grid.Column="2"
                            Style="{StaticResource MaterialDesignIconButton}"
                            CommandParameter="{Binding}"
                            Click="DeleteTask_Click"
                            ToolTip="删除任务">
                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
                    </Button>
                </Grid>
            </materialDesign:Card>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="TaskReminder" 
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                           FontWeight="Bold"/>
                <TextBlock Text="定时提醒工具" 
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                           Opacity="0.7"/>
                <TextBlock x:Name="StatusText"
                           Text="就绪"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.5"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 操作按钮 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Width="120"
                        Click="AddTask_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="新建任务"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Width="100"
                        Margin="12,0,0,0"
                        Click="RefreshTasks_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区域：左右分栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：任务列表 -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource MaterialDesignCardBackground}" 
                    CornerRadius="8"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表标题和筛选 -->
                    <Grid Grid.Row="0" Margin="16,12,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="任务列表" 
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TaskCountText"
                                       Text="共 0 个任务"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.6"/>
                        </StackPanel>
                        <!-- 按周期筛选（Bug 4 修复） -->
                        <ComboBox x:Name="FilterRepeatTypeComboBox" 
                                  Grid.Column="1" 
                                  Width="100" 
                                  Style="{StaticResource MaterialDesignComboBox}"
                                  materialDesign:HintAssist.Hint="筛选"
                                  SelectionChanged="FilterRepeatType_SelectionChanged">
                            <ComboBoxItem Content="全部" Tag="all" IsSelected="True"/>
                            <ComboBoxItem Content="每日" Tag="1"/>
                            <ComboBoxItem Content="每周" Tag="2"/>
                            <ComboBoxItem Content="每月" Tag="3"/>
                            <ComboBoxItem Content="每季度" Tag="4"/>
                            <ComboBoxItem Content="每年" Tag="5"/>
                        </ComboBox>
                    </Grid>

                    <!-- ListView -->
                    <ListView x:Name="TaskListView"
                              Grid.Row="1"
                              ItemTemplate="{StaticResource TaskItemTemplate}"
                              SelectionChanged="TaskListView_SelectionChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="0"
                              Margin="16,0,16,16">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                </Grid>
            </Border>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- 右侧：任务详情 -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource MaterialDesignCardBackground}" 
                    CornerRadius="8"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1">
                <Grid x:Name="DetailGrid" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 详情标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="任务详情" 
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <!-- 详情内容 -->
                    <StackPanel Grid.Row="1" x:Name="DetailContent">
                        <TextBlock Text="未选择任务" 
                                   Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                   Opacity="0.5"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"/>
                    </StackPanel>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="100"
                                Click="EditTask_Click"
                                IsEnabled="False"
                                x:Name="EditButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Edit" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="编辑"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="100"
                                Margin="12,0,0,0"
                                Click="DeleteTask_Click"
                                IsEnabled="False"
                                x:Name="DeleteButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="删除"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
