<Window x:Class="TaskReminder.Views.AddEditTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:TaskReminder.Models"
        Title="添加/编辑任务" 
        Height="500" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="TitleText" 
                       Text="添加新任务" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       FontWeight="Bold"/>
        </StackPanel>

        <!-- 表单内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 标题 -->
                <TextBox x:Name="TitleTextBox"
                         materialDesign:HintAssist.Hint="任务标题 *"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,16"
                         MaxLength="100"/>

                <!-- 描述 -->
                <TextBox x:Name="DescriptionTextBox"
                         materialDesign:HintAssist.Hint="任务描述"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,16"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MaxLength="500"
                         Height="80"/>

                <!-- 到期时间 -->
                <DatePicker x:Name="DueDatePicker"
                            materialDesign:HintAssist.Hint="到期时间 *"
                            Style="{StaticResource MaterialDesignDatePicker}"
                            Margin="0,0,0,16"/>

                <!-- 时间选择器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="选择时间：" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <ComboBox x:Name="HourComboBox" 
                              Width="60" 
                              Margin="0,0,8,0"
                              Style="{StaticResource MaterialDesignComboBox}"/>
                    <TextBlock Text=":" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <ComboBox x:Name="MinuteComboBox" 
                              Width="60"
                              Style="{StaticResource MaterialDesignComboBox}"/>
                </StackPanel>

                <!-- 重复类型 -->
                <ComboBox x:Name="RepeatTypeComboBox"
                          materialDesign:HintAssist.Hint="重复类型"
                          Style="{StaticResource MaterialDesignComboBox}"
                          Margin="0,0,0,16">
                    <ComboBoxItem Content="不重复" Tag="0"/>
                    <ComboBoxItem Content="每天" Tag="1"/>
                    <ComboBoxItem Content="每周" Tag="2"/>
                    <ComboBoxItem Content="每月" Tag="3"/>
                    <ComboBoxItem Content="每季度" Tag="4"/>
                    <ComboBoxItem Content="每年" Tag="5"/>
                </ComboBox>

                <!-- 重复间隔 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox x:Name="RepeatIntervalTextBox"
                             materialDesign:HintAssist.Hint="间隔"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Width="80"
                             Text="1"/>
                    <TextBlock Text=" 个单位" 
                               VerticalAlignment="Center" 
                               Margin="8,0,0,0"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,24,0,0">
            <Button Content="取消" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="100"
                    Margin="0,0,16,0"
                    Click="CancelButton_Click"/>
            <Button Content="保存" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="100"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
